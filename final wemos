// ================= MODE =================

enum State {
  ANIMATION,
  GREETING,
  PHOTOS
};

State currentState = ANIMATION;

// ================= PAGE =================

int animationFrame = 0;
int greetingPage = 0;
int photoPage = 0;

// ================= TIMER =================

unsigned long lastFrameTime = 0;
const int FRAME_INTERVAL = 250;

// ================= TOUCH =================

bool lastTouch = false;
unsigned long lastTouchTime = 0;
const int debounceTime = 250;

// ================= MUSIC =================

bool musicStarted = false;
bool songFinished = false;

const int melody[] = {
  264,264,297,264,352,330,
  264,264,297,264,396,352,
  264,264,528,440,352,330,297,
  466,466,440,352,396,352
};

const int noteDuration[] = {
  250,250,500,500,500,1000,
  250,250,500,500,500,1000,
  250,250,500,500,500,500,1000,
  250,250,500,500,500,1000
};

int currentNote = 0;
unsigned long noteStartTime = 0;
bool notePlaying = false;

const int TOTAL_NOTES =
sizeof(melody)/sizeof(melody[0]);

// =========================================

void startSong()
{
  musicStarted = true;
  currentNote = 0;
  notePlaying = false;
}

void updateSong()
{
  if(!musicStarted || songFinished)
    return;

  unsigned long now = millis();

  if(!notePlaying)
  {
    tone(BUZZER_PIN, melody[currentNote]);

    noteStartTime = now;
    notePlaying = true;
  }
  else
  {
    if(now - noteStartTime >= noteDuration[currentNote])
    {
      noTone(BUZZER_PIN);

      currentNote++;

      notePlaying = false;

      if(currentNote >= TOTAL_NOTES)
      {
        songFinished = true;
        noTone(BUZZER_PIN);
      }
    }
  }
}

// =========================================

void drawCake(int frame)
{
  display.clearDisplay();

  display.drawBitmap(
    0,
    0,
    cakes[frame],
    128,
    64,
    WHITE
  );

  display.display();
}

// =========================================

void drawGreeting(int page)
{
  display.clearDisplay();

  display.setTextColor(WHITE);
  display.setTextSize(1);

  switch(page)
  {
    case 0:
      display.setCursor(10,20);
      display.println("Selamat Ulang Tahun");
      break;

    case 1:
      display.setCursor(10,20);
      display.println("Semoga Sehat Selalu");
      break;

    case 2:
      display.setCursor(10,20);
      display.println("Panjang Umur");
      break;

    case 3:
      display.setCursor(10,20);
      display.println("Semoga Bahagia");
      break;

    case 4:
      display.setCursor(10,20);
      display.println("Happy Birthday!");
      break;
  }

  display.display();
}

// =========================================

void drawPhoto(int index)
{
  display.clearDisplay();

  display.drawBitmap(
    0,
    0,
    photos[index],
    128,
    64,
    WHITE
  );

  display.display();
}

// =========================================

void nextPage()
{
  if(currentState == ANIMATION)
  {
    currentState = GREETING;
    greetingPage = 0;

    if(!musicStarted)
      startSong();

    drawGreeting(greetingPage);
  }

  else if(currentState == GREETING)
  {
    greetingPage++;

    if(greetingPage < 5)
    {
      drawGreeting(greetingPage);
    }
    else
    {
      currentState = PHOTOS;
      photoPage = 0;

      drawPhoto(photoPage);
    }
  }

  else if(currentState == PHOTOS)
  {
    photoPage++;

    if(photoPage < 10)
    {
      drawPhoto(photoPage);
    }
    else
    {
      // selesai

      currentState = ANIMATION;
      animationFrame = 0;

      drawCake(animationFrame);
    }
  }
}

// =========================================

void setup()
{
  pinMode(TOUCH_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  Wire.begin(D2, D1);

  display.begin(
    SSD1306_SWITCHCAPVCC,
    0x3C
  );

  display.clearDisplay();
  display.display();

  drawCake(0);
}

// =========================================

void loop()
{
  updateSong();

  // animasi kue otomatis
  if(currentState == ANIMATION)
  {
    if(millis() - lastFrameTime > FRAME_INTERVAL)
    {
      animationFrame++;

      if(animationFrame >= 9)
        animationFrame = 0;

      drawCake(animationFrame);

      lastFrameTime = millis();
    }
  }

  bool touch = digitalRead(TOUCH_PIN);

  if(
      touch &&
      !lastTouch &&
      millis() - lastTouchTime > debounceTime
    )
  {
    nextPage();

    lastTouchTime = millis();
  }

  lastTouch = touch;
}
